<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:T3Code.Native.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1120" d:DesignHeight="760"
             x:Class="T3Code.Native.App.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto" Background="#101114">
    <Border Grid.Row="0" Background="#17191f" BorderBrush="#2a2f3a" BorderThickness="0,0,0,1" Padding="16,12">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
          <Button Grid.Column="0"
                  Command="{Binding ScanBackendsCommand}"
                  Content="Scan"
                  MinWidth="76" />
          <TextBox Grid.Column="1"
                   Text="{Binding BaseUrl}"
                   PlaceholderText="Discover or enter http://vpn-or-lan-ip:3773" />
          <Button Grid.Column="2"
                  Command="{Binding PairCommand}"
                  Content="Pair"
                  MinWidth="76" />
        </Grid>
        <ComboBox ItemsSource="{Binding DiscoveredBackends}"
                  SelectedItem="{Binding SelectedBackend}"
                  HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate DataType="vm:DiscoveredBackendItem">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding BaseUrl}" Foreground="#f2f5f9" />
                <TextBlock Text="{Binding Source}" Foreground="#8c95a4" FontSize="12" />
              </StackPanel>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBox Text="{Binding PairingToken}"
                 PlaceholderText="Pairing token or URL" />
        <StackPanel Spacing="2">
          <TextBlock Text="{Binding ServerName}" Foreground="#f2f5f9" FontWeight="SemiBold" TextWrapping="Wrap" />
          <TextBlock Text="{Binding Protocol}" Foreground="#aab2c0" FontSize="12" />
        </StackPanel>
      </StackPanel>
    </Border>

    <TabControl Grid.Row="1" Background="#101114">
      <TabItem Header="Projects" Foreground="#f2f5f9">
        <Border Background="#15171c" Padding="12">
          <ListBox ItemsSource="{Binding Projects}"
                   SelectedItem="{Binding SelectedProject}"
                   Background="Transparent"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:ProjectShellItem">
                <StackPanel Margin="0,4" Spacing="2">
                  <TextBlock Text="{Binding Title}" Foreground="#f2f5f9" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Detail}" Foreground="#8c95a4" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </TabItem>

      <TabItem Header="Threads" Foreground="#f2f5f9">
        <Border Background="#181b21" Padding="12">
        <Grid RowDefinitions="Auto,Auto,*">
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
              <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate DataType="vm:ModelSelectionItem">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <ComboBox ItemsSource="{Binding RuntimeModes}" SelectedItem="{Binding SelectedRuntimeMode}" HorizontalAlignment="Stretch" />
              <ComboBox ItemsSource="{Binding InteractionModes}" SelectedItem="{Binding SelectedInteractionMode}" HorizontalAlignment="Stretch" />
            </StackPanel>
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Threads}"
                     SelectedItem="{Binding SelectedThread}"
                     Background="Transparent"
                     BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:ThreadShellItem">
                <StackPanel Margin="0,4" Spacing="2">
                  <TextBlock Text="{Binding Title}" Foreground="#f2f5f9" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Detail}" Foreground="#8c95a4" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
        </Border>
      </TabItem>

      <TabItem Header="Chat" Foreground="#f2f5f9">
        <Border Background="#101114" Padding="16">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock Text="Chat" Foreground="#f2f5f9" FontSize="20" FontWeight="SemiBold" />
          <ListBox Grid.Row="1"
                   Margin="0,12"
                   ItemsSource="{Binding ChatLines}"
                   Background="Transparent"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:ChatLineItem">
                  <Border Background="{Binding Background}"
                          BorderBrush="{Binding BorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10"
                          Margin="0,0,0,8">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Speaker}" Foreground="{Binding SpeakerForeground}" FontSize="12" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Text}" Foreground="#f2f5f9" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <TextBox Text="{Binding ComposerText}" PlaceholderText="Send a turn" MinHeight="44" AcceptsReturn="True" />
              <Button Grid.Column="1" Command="{Binding ContinueThreadCommand}" Content="Continue" MinWidth="88" />
              <Button Grid.Column="2" Command="{Binding StopThreadCommand}" Content="Stop" MinWidth="64" />
              <Button Grid.Column="3" Command="{Binding QueueComposerCommand}" Content="Send" MinWidth="76" />
          </Grid>
        </Grid>
      </Border>
      </TabItem>

      <TabItem Header="Diff" Foreground="#f2f5f9">
        <Border Background="#101114" Padding="16">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <Grid ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding DiffFromTurn}" PlaceholderText="From" />
              <TextBox Grid.Column="1" Text="{Binding DiffToTurn}" PlaceholderText="To" />
              <Button Grid.Column="2" Command="{Binding LoadTurnDiffCommand}" Content="Turn" MinWidth="72" />
              <Button Grid.Column="3" Command="{Binding LoadFullThreadDiffCommand}" Content="Full" MinWidth="72" />
            </Grid>
            <TextBlock Grid.Row="1" Text="{Binding DiffStatus}" Foreground="#aab2c0" TextWrapping="Wrap" />
            <Border Grid.Row="2" Background="#0d0f12" BorderBrush="#2a2f3a" BorderThickness="1">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding DiffText}"
                           TextWrapping="NoWrap"
                           FontFamily="Consolas, Menlo, monospace"
                           FontSize="12"
                           Foreground="#e5e7eb"
                           Padding="10" />
              </ScrollViewer>
            </Border>
          </Grid>
        </Border>
      </TabItem>

      <TabItem Header="Git" Foreground="#f2f5f9">
        <Border Background="#101114" Padding="16">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding GitCommitMessage}" PlaceholderText="Commit message" />
              <Button Grid.Column="1" Command="{Binding RefreshGitStatusCommand}" Content="Refresh" MinWidth="84" />
            </Grid>
            <StackPanel Grid.Row="1" Spacing="8">
              <TextBlock Text="{Binding GitStatusText}" Foreground="#aab2c0" TextWrapping="Wrap" />
              <WrapPanel>
                <Button Command="{Binding RunGitCommitCommand}" Content="Commit" Margin="0,0,8,8" />
                <Button Command="{Binding RunGitPushCommand}" Content="Push" Margin="0,0,8,8" />
                <Button Command="{Binding RunGitCommitPushCommand}" Content="Commit+Push" Margin="0,0,8,8" />
                <Button Command="{Binding RunGitPrPrepCommand}" Content="PR prep" Margin="0,0,8,8" />
              </WrapPanel>
            </StackPanel>
            <Border Grid.Row="2" Background="#0d0f12" BorderBrush="#2a2f3a" BorderThickness="1">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GitLogLines}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}"
                                 Foreground="#e5e7eb"
                                 FontFamily="Consolas, Menlo, monospace"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 Margin="10,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </Grid>
        </Border>
      </TabItem>

      <TabItem Header="Files" Foreground="#f2f5f9">
        <Border Background="#101114" Padding="16">
          <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding BrowsePath}" PlaceholderText="Path to browse on desktop backend" />
              <Button Grid.Column="1" Command="{Binding BrowseWorkspaceCommand}" Content="Browse" MinWidth="84" />
            </Grid>
            <TextBlock Grid.Row="1" Text="{Binding WorkspaceStatus}" Foreground="#aab2c0" TextWrapping="Wrap" />
            <ListBox Grid.Row="2" ItemsSource="{Binding WorkspaceEntries}" Background="Transparent" BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:WorkspaceEntryItem">
                  <StackPanel Margin="0,4" Spacing="2">
                    <TextBlock Text="{Binding Name}" Foreground="#f2f5f9" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FullPath}" Foreground="#8c95a4" FontSize="12" TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Row="3" Spacing="8">
              <TextBox Text="{Binding ProjectTitle}" PlaceholderText="Project title" />
              <TextBox Text="{Binding ProjectWorkspacePath}" PlaceholderText="Workspace path" />
              <Button Command="{Binding CreateProjectCommand}" Content="Add project" HorizontalAlignment="Stretch" />
              <TextBox Text="{Binding CloneRemoteUrl}" PlaceholderText="Repository URL" />
              <TextBox Text="{Binding CloneDestinationPath}" PlaceholderText="Clone destination path" />
              <Button Command="{Binding CloneRepositoryCommand}" Content="Clone and add project" HorizontalAlignment="Stretch" />
            </StackPanel>
          </Grid>
        </Border>
      </TabItem>

      <TabItem Header="Terminal" Foreground="#f2f5f9">
        <Border Background="#101114" Padding="16">
          <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding TerminalCwd}" PlaceholderText="Terminal cwd" />
              <Button Grid.Column="1" Command="{Binding OpenTerminalCommand}" Content="Open" MinWidth="68" />
              <Button Grid.Column="2" Command="{Binding ClearTerminalCommand}" Content="Clear" MinWidth="68" />
              <Button Grid.Column="3" Command="{Binding RestartTerminalCommand}" Content="Restart" MinWidth="78" />
              <Button Grid.Column="4" Command="{Binding CloseTerminalCommand}" Content="Close" MinWidth="68" />
            </Grid>
            <TextBlock Grid.Row="1" Text="{Binding TerminalStatus}" Foreground="#aab2c0" TextWrapping="Wrap" />
            <Border Grid.Row="2" Background="#0d0f12" BorderBrush="#2a2f3a" BorderThickness="1">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding TerminalLines}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}"
                                 Foreground="#e5e7eb"
                                 FontFamily="Consolas, Menlo, monospace"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 Margin="10,3" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding TerminalInput}" PlaceholderText="Terminal input" MinHeight="44" />
              <Button Grid.Column="1" Command="{Binding SendTerminalInputCommand}" Content="Send" MinWidth="76" />
            </Grid>
          </Grid>
        </Border>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2" Background="#17191f" BorderBrush="#2a2f3a" BorderThickness="0,1,0,0" Padding="12,8">
      <TextBlock Text="{Binding Status}" Foreground="#aab2c0" TextWrapping="Wrap" />
    </Border>
  </Grid>
</UserControl>
